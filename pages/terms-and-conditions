<style>
/* ══ prefix: tc- ══════════════════════════════════════════════════ */
#tc-wrap {
  --acc: #2563EB;
  --acc-lt: #EFF6FF;
  --acc-bd: #BFDBFE;
  --txt: #111827;
  --txt2: #6B7280;
  --bdr: #E5E7EB;
  --bg: #F9FAFB;
  --card: #FFFFFF;
  font-family: inherit;
  direction: rtl;
  box-sizing: border-box;
}
#tc-wrap *, #tc-wrap *::before, #tc-wrap *::after { box-sizing: border-box; }

@keyframes tc-in { from { opacity: 0; transform: translateY(8px) } to { opacity: 1; transform: translateY(0) } }

.tc-body {
  max-width: 680px;
  width: 100%;
  margin: 0 auto;
  padding: 4px 0 48px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  animation: tc-in .35s ease;
}

/* ── hero ── */
.tc-hero {
  background: linear-gradient(135deg, #1e3a8a 0%, #2563EB 100%);
  border-radius: 20px;
  padding: 28px 24px;
  display: flex;
  align-items: center;
  gap: 18px;
  color: #fff;
}
.tc-hero__icon {
  width: 56px;
  height: 56px;
  border-radius: 16px;
  background: rgba(255,255,255,.18);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  flex-shrink: 0;
}
.tc-hero__title { font-size: 20px; font-weight: 900; margin-bottom: 4px; }
.tc-hero__sub   { font-size: 13px; opacity: .82; font-weight: 500; }

/* ── section card ── */
.tc-card {
  background: var(--card);
  border: 1.5px solid var(--bdr);
  border-radius: 18px;
  overflow: hidden;
}
.tc-card__head {
  padding: 16px 20px;
  border-bottom: 1px solid var(--bdr);
  display: flex;
  align-items: center;
  gap: 12px;
  background: var(--bg);
}
.tc-card__ico {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  background: var(--acc-lt);
  color: var(--acc);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  flex-shrink: 0;
}
.tc-card__title { font-size: 14px; font-weight: 800; color: var(--txt); }
.tc-card__body  { padding: 18px 20px; }

/* ── text elements ── */
.tc-p {
  font-size: 14px;
  color: var(--txt2);
  line-height: 1.85;
  margin: 0 0 12px;
}
.tc-p:last-child { margin-bottom: 0; }
.tc-p b { color: var(--txt); }

.tc-list {
  list-style: none;
  padding: 0;
  margin: 0 0 12px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.tc-list:last-child { margin-bottom: 0; }
.tc-list li {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  font-size: 14px;
  color: var(--txt2);
  line-height: 1.7;
}
.tc-list li::before {
  content: '';
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--acc);
  flex-shrink: 0;
  margin-top: 7px;
}
.tc-list li b { color: var(--txt); }

/* ── note box ── */
.tc-note {
  background: #FFF7ED;
  border: 1px solid #FED7AA;
  border-radius: 12px;
  padding: 13px 16px;
  font-size: 13px;
  color: #92400E;
  line-height: 1.7;
  display: flex;
  gap: 10px;
  align-items: flex-start;
  margin-top: 12px;
}
.tc-note i { font-size: 18px; color: #D97706; flex-shrink: 0; margin-top: 1px; }

.tc-note-blue {
  background: var(--acc-lt);
  border: 1px solid var(--acc-bd);
  border-radius: 12px;
  padding: 13px 16px;
  font-size: 13px;
  color: #1e40af;
  line-height: 1.7;
  display: flex;
  gap: 10px;
  align-items: flex-start;
  margin-top: 12px;
}
.tc-note-blue i { font-size: 18px; color: var(--acc); flex-shrink: 0; margin-top: 1px; }

/* ── footer card ── */
.tc-footer {
  background: var(--acc-lt);
  border: 1.5px solid var(--acc-bd);
  border-radius: 18px;
  padding: 20px;
  text-align: center;
}
.tc-footer__title { font-size: 14px; font-weight: 800; color: var(--acc); margin-bottom: 6px; }
.tc-footer__sub   { font-size: 13px; color: var(--txt2); margin-bottom: 14px; line-height: 1.7; }
.tc-footer a {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  height: 42px;
  padding: 0 22px;
  background: var(--acc);
  color: #fff;
  border-radius: 12px;
  font-size: 13px;
  font-weight: 800;
  text-decoration: none;
  transition: background .15s;
}
.tc-footer a:hover { background: #1D4ED8; }

/* ── date chip ── */
.tc-date {
  text-align: center;
  font-size: 12px;
  color: var(--txt2);
  padding: 4px 0 2px;
}
</style>

