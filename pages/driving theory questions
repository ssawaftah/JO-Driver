<script>
(function(){
'use strict';

/* ── Firebase ── */
var FB={
  apiKey: "AIzaSyBBFk8kQgf7qRKy-Psi18-jSv4qmeTYQBQ",
  authDomain: "driverjo.firebaseapp.com",
  databaseURL: "https://driverjo-default-rtdb.firebaseio.com",
  projectId: "driverjo",
  storageBucket: "driverjo.firebasestorage.app",
  messagingSenderId: "716209135475",
  appId: "1:716209135475:web:0a8188a18017c5880aaf06"
};

/* ── Categories ── */
var CATS=[
  {name:"قواعد السير والمرور",        icon:"ph-traffic-cone"},
  {name:"الميكانيك",                  icon:"ph-wrench"},
  {name:"السلامة على الطريق",         icon:"ph-shield-check"},
  {name:"أسعافات أولية",             icon:"ph-first-aid"},
  {name:"الشواخص والخطوط والعلامات", icon:"ph-signpost"},
  {name:"المخالفات واحتساب النقاط",  icon:"ph-gavel"},
  {name:"الصور المتحركة",             icon:"ph-film-strip"}
];

/* ── cache ── */
var CACHE_KEY='qax_questions_v1';
var CACHE_TTL=24*60*60*1000; // 24 ساعة

function saveCache(data){
  try{localStorage.setItem(CACHE_KEY,JSON.stringify({ts:Date.now(),data:data}))}catch(e){}
}
function loadCache(){
  try{
    var raw=localStorage.getItem(CACHE_KEY);
    if(!raw)return null;
    var obj=JSON.parse(raw);
    if(Date.now()-obj.ts>CACHE_TTL){localStorage.removeItem(CACHE_KEY);return null}
    return obj.data;
  }catch(e){return null}
}

/* ── state ── */
var allQ={},catName=null,qs=[],idx=0,score=0,answered=false;

/* ── pages ── */
var P={
  loading: document.getElementById('qax-loading'),
  cats:    document.getElementById('qax-page-cats'),
  rev:     document.getElementById('qax-page-rev'),
  revdone: document.getElementById('qax-page-rev-done'),
  exam:    document.getElementById('qax-page-exam'),
  result:  document.getElementById('qax-page-result')
};

window.qaxGo=function(name){
  Object.values(P).forEach(function(p){p.classList.add('qax-hide')});
  P[name].classList.remove('qax-hide');
  try{window.scrollTo(0,0)}catch(e){}
};

/* ── audio ── */
var _ac=null;
function ac(){if(!_ac)try{_ac=new(window.AudioContext||window.webkitAudioContext)()}catch(e){}return _ac}
function sndOk(){
  var c=ac();if(!c)return;
  [[523,0],[659,.1],[784,.2],[1047,.32]].forEach(function(p){
    var o=c.createOscillator(),g=c.createGain();
    o.connect(g);g.connect(c.destination);o.type='sine';o.frequency.value=p[0];
    g.gain.setValueAtTime(0,c.currentTime+p[1]);
    g.gain.linearRampToValueAtTime(.18,c.currentTime+p[1]+.03);
    g.gain.exponentialRampToValueAtTime(.001,c.currentTime+p[1]+.35);
    o.start(c.currentTime+p[1]);o.stop(c.currentTime+p[1]+.38);
  });
}
function sndBad(){
  var c=ac();if(!c)return;
  [[220,0],[165,.1],[110,.2]].forEach(function(p){
    var o=c.createOscillator(),g=c.createGain();
    o.connect(g);g.connect(c.destination);o.type='sawtooth';o.frequency.value=p[0];
    g.gain.setValueAtTime(.18,c.currentTime+p[1]);
    g.gain.exponentialRampToValueAtTime(.001,c.currentTime+p[1]+.22);
    o.start(c.currentTime+p[1]);o.stop(c.currentTime+p[1]+.25);
  });
}

/* ── helpers ── */
function norm(s){
  return String(s||'').replace(/[إأآٱ]/g,'ا').replace(/ى/g,'ي')
    .replace(/ة/g,'ه').replace(/[\u064B-\u065F\u0670]/g,'').trim();
}
function matchCat(r){var n=norm(r),f=CATS.find(function(c){return norm(c.name)===n});return f?f.name:r}
function shuffle(a){var r=a.slice();for(var i=r.length-1;i>0;i--){var j=Math.floor(Math.random()*(i+1));var t=r[i];r[i]=r[j];r[j]=t}return r}
function setMedia(q,wrap,img,vid){
  if(q.mediaUrl&&q.mediaType!=='text'){
    wrap.classList.remove('qax-hide');
    if(q.mediaType==='video'){img.classList.add('qax-hide');vid.classList.remove('qax-hide');vid.src=q.mediaUrl}
    else{vid.classList.add('qax-hide');img.classList.remove('qax-hide');img.src=q.mediaUrl}
  }else wrap.classList.add('qax-hide');
}

/* ── Firebase ── */
function initFB(){
  if(!window.firebase)return null;
  if(!firebase.apps||!firebase.apps.length)firebase.initializeApp(FB);
  else try{firebase.app()}catch(e){firebase.initializeApp(FB)}
  return firebase.database();
}

function parseRaw(raw){
  var result={};
  Object.values(raw).forEach(function(q){
    var c=matchCat(q.category||CATS[0].name);
    if(!result[c])result[c]=[];result[c].push(q);
  });
  return result;
}

function fetchAndRefresh(silent){
  function tryFetch(){
    var db=initFB();
    if(!db){setTimeout(tryFetch,300);return}
    db.ref('questions').once('value').then(function(snap){
      var raw=snap.val()||{};
      var fresh=parseRaw(raw);
      saveCache(fresh);
      // تحديث واجهة المستخدم إذا كان المستخدم لا يزال في صفحة الأقسام
      if(!silent||document.getElementById('qax-page-cats').classList.contains('qax-hide')===false){
        allQ=fresh;buildCats();
      }else{
        allQ=fresh; // تحديث البيانات في الذاكرة فقط
      }
    }).catch(function(){/* صامت عند الفشل */});
  }
  tryFetch();
}

function load(){
  var cached=loadCache();
  if(cached){
    // عرض فوري من الكاش
    allQ=cached;
    buildCats();
    qaxGo('cats');
    // تحديث صامت في الخلفية
    fetchAndRefresh(true);
  }else{
    // أول زيارة: إخفاء شاشة التحميل وعرض الأقسام فارغة ثم التحديث
    buildCats();
    qaxGo('cats');
    fetchAndRefresh(false);
  }
}

/* ── build cats ── */
function buildCats(){
  var total=Object.values(allQ).reduce(function(s,a){return s+a.length},0);
  document.getElementById('qax-all-cnt').textContent=total+' سؤال في كل الأقسام';
  var list=document.getElementById('qax-cat-list');list.textContent='';
  CATS.forEach(function(cat,di){
    var count=(allQ[cat.name]||[]).length;
    var row=document.createElement('div');
    row.className='qax-cat-row';
    row.style.animationDelay=(di*.06)+'s';

    var ico=document.createElement('div');ico.className='qax-cat-ico';
    var ii=document.createElement('i');ii.className='ph '+cat.icon;
    ico.appendChild(ii);

    var info=document.createElement('div');info.className='qax-cat-info';
    var nm=document.createElement('div');nm.className='qax-cat-name';nm.textContent=cat.name;
    var cn=document.createElement('div');cn.className='qax-cat-cnt';cn.textContent=count+' سؤال';
    info.appendChild(nm);info.appendChild(cn);

    var btns=document.createElement('div');btns.className='qax-cat-btns';

    var rb=document.createElement('button');rb.className='qax-btn-card-rev';
    var ri=document.createElement('i');ri.className='ph ph-eye';
    rb.appendChild(ri);rb.appendChild(document.createTextNode('مراجعة'));
    rb.addEventListener('click',(function(c){return function(){startRev(c.name,(allQ[c.name]||[]).slice())}})(cat));

    var eb=document.createElement('button');eb.className='qax-btn-card-exam';
    var ei=document.createElement('i');ei.className='ph ph-lightning';
    eb.appendChild(ei);eb.appendChild(document.createTextNode('اختبار'));
    eb.addEventListener('click',(function(c){return function(){startExam(c.name,(allQ[c.name]||[]).slice())}})(cat));

    btns.appendChild(rb);btns.appendChild(eb);
    row.appendChild(ico);row.appendChild(info);row.appendChild(btns);
    list.appendChild(row);
  });
}

/* ── review ── */
function startRev(name,questions){
  catName=name;qs=questions;idx=0;
  var empty=document.getElementById('qax-rev-empty');
  var body=document.getElementById('qax-rev-body');
  var foot=document.getElementById('qax-rev-foot');
  empty.classList.add('qax-hide');body.classList.remove('qax-hide');foot.classList.remove('qax-hide');
  qaxGo('rev');
  if(!qs.length){empty.classList.remove('qax-hide');body.classList.add('qax-hide');foot.classList.add('qax-hide');return}
  renderRev();
}
function renderRev(){
  var q=qs[idx],total=qs.length,last=idx>=total-1;
  document.getElementById('qax-rev-title').textContent=catName;
  document.getElementById('qax-rev-idx').textContent=(idx+1)+' / '+total;
  document.getElementById('qax-rev-bar').style.width=Math.round(((idx+1)/total)*100)+'%';
  setMedia(q,document.getElementById('qax-rev-media'),document.getElementById('qax-rev-img'),document.getElementById('qax-rev-vid'));
  document.getElementById('qax-rev-qtxt').textContent=q.question;
  var opts=document.getElementById('qax-rev-opts');opts.textContent='';
  (q.options||[]).forEach(function(opt,i){
    var row=document.createElement('div');
    row.className='qax-ropt'+(i===q.correctAnswer?' qax-correct':'');
    var dot=document.createElement('div');dot.className='qax-ropt-dot';
    if(i===q.correctAnswer){var ck=document.createElement('i');ck.className='ph ph-check';dot.appendChild(ck)}
    // ابحث عن هذا الجزء داخل دالة renderRev
else dot.textContent = ['أ', 'ب', 'ج', 'د', 'هـ'][i];
    var lbl=document.createElement('span');lbl.className='qax-ropt-lbl';lbl.textContent=opt;
    row.appendChild(dot);row.appendChild(lbl);opts.appendChild(row);
  });
  var ex=document.getElementById('qax-rev-expl');
  if(q.explanation){document.getElementById('qax-rev-expl-txt').textContent=q.explanation;ex.classList.remove('qax-hide')}
  else ex.classList.add('qax-hide');
  document.getElementById('qax-rev-prev').disabled=idx===0;
  var nl=document.getElementById('qax-rev-nlbl'),ni=document.getElementById('qax-rev-nico'),nb=document.getElementById('qax-rev-next');
  if(last){nl.textContent='إنهاء المراجعة';ni.className='ph ph-check-circle';nb.classList.add('qax-fin')}
  else{nl.textContent='التالي';ni.className='ph ph-arrow-left';nb.classList.remove('qax-fin')}
}

/* ── exam ── */
function startExam(name,questions){
  catName=name;qs=shuffle(questions);idx=0;score=0;answered=false;
  var empty=document.getElementById('qax-exam-empty');
  var body=document.getElementById('qax-exam-body');
  empty.classList.add('qax-hide');body.classList.remove('qax-hide');
  document.getElementById('qax-exam-foot').classList.add('qax-hide');
  qaxGo('exam');
  if(!qs.length){empty.classList.remove('qax-hide');body.classList.add('qax-hide');return}
  renderExam();
}
function renderExam(){
  var q=qs[idx],total=qs.length,last=idx>=total-1;
  answered=false;
  document.getElementById('qax-exam-title').textContent=catName;
  document.getElementById('qax-score-num').textContent=score;
  document.getElementById('qax-exam-idx').textContent=(idx+1)+' / '+total;
  document.getElementById('qax-exam-bar').style.width=Math.round(((idx+1)/total)*100)+'%';
  setMedia(q,document.getElementById('qax-exam-media'),document.getElementById('qax-exam-img'),document.getElementById('qax-exam-vid'));
  document.getElementById('qax-exam-qtxt').textContent=q.question;
  var opts=document.getElementById('qax-exam-opts');opts.textContent='';
  (q.options||[]).forEach(function(opt,i){
    var btn=document.createElement('button');btn.className='qax-eopt';
    // ابحث عن هذا الجزء داخل دالة renderExam
var dot = document.createElement('div');
dot.className = 'qax-eopt-dot';
dot.textContent = ['أ', 'ب', 'ج', 'د', 'هـ'][i]; // التعديل هنا
    var lbl=document.createElement('span');lbl.className='qax-eopt-lbl';lbl.textContent=opt;
    btn.appendChild(dot);btn.appendChild(lbl);
    btn.addEventListener('click',(function(ch){return function(){handleAns(ch,q.correctAnswer)}})(i));
    opts.appendChild(btn);
  });
  var fb=document.getElementById('qax-exam-fb');fb.className='qax-hide';fb.textContent='';
  document.getElementById('qax-exam-foot').classList.add('qax-hide');
  var nl=document.getElementById('qax-nxt-lbl'),ni=document.getElementById('qax-nxt-ico'),nb=document.getElementById('qax-exam-nxt');
  if(last){nl.textContent='عرض النتيجة';ni.className='ph ph-flag-checkered';nb.classList.add('qax-nxt-last')}
  else{nl.textContent='السؤال التالي';ni.className='ph ph-arrow-left';nb.classList.remove('qax-nxt-last')}
}
function handleAns(chosen,correct){
  if(answered)return;answered=true;
  var ok=chosen===correct;
  if(ok){score++;document.getElementById('qax-score-num').textContent=score;sndOk()}else sndBad();
  document.getElementById('qax-exam-opts').querySelectorAll('.qax-eopt').forEach(function(b,i){
    b.disabled=true;
    if(i===chosen&&ok)b.classList.add('qax-e-ok');
    else if(i===chosen)b.classList.add('qax-e-bad');
    else if(i===correct)b.classList.add('qax-e-show');
    else b.classList.add('qax-e-dim');
  });
  var fb=document.getElementById('qax-exam-fb');fb.textContent='';
  var ico=document.createElement('i');
  if(ok){
    fb.className='qax-fb qax-fb-ok';ico.className='ph ph-check-circle';
    fb.appendChild(ico);fb.appendChild(document.createTextNode(' إجابة صحيحة'));
  }else{
    fb.className='qax-fb qax-fb-bad';ico.className='ph ph-x-circle';
     fb.appendChild(ico);fb.appendChild(document.createTextNode(' إجابة خاطئة - الصحيحة باللون الأخضر'));
  }
  document.getElementById('qax-exam-foot').classList.remove('qax-hide');
}

/* ── result ── */
function showResult(){
  var total=qs.length,pct=total?Math.round(score/total*100):0;
  var circ=2*Math.PI*55,dash=circ-circ*pct/100;
  var clr=pct>=90?'#16A34A':pct>=70?'#2563EB':pct>=50?'#D97706':'#DC2626';
  var hd=pct>=90?'ممتاز':pct>=70?'جيد جداً':pct>=50?'مقبول':'تحتاج مراجعة';
  var arc=document.getElementById('qax-ring-arc');
  arc.setAttribute('stroke',clr);
  arc.setAttribute('stroke-dasharray',circ);
  arc.setAttribute('stroke-dashoffset',circ);
  setTimeout(function(){arc.setAttribute('stroke-dashoffset',dash)},80);
  document.getElementById('qax-res-pct').textContent=pct+'%';
  document.getElementById('qax-res-h').textContent=hd;
  var rp=document.getElementById('qax-res-p');rp.innerHTML='';
  rp.appendChild(document.createTextNode('أجبت على '));
  var s1=document.createElement('strong');s1.textContent=score;rp.appendChild(s1);
  rp.appendChild(document.createTextNode(' من '));
  var s2=document.createElement('strong');s2.textContent=total;rp.appendChild(s2);
  rp.appendChild(document.createTextNode(' سؤال بشكل صحيح'));
  qaxGo('result');
}

/* ── events ── */
document.getElementById('qax-all-rev').addEventListener('click',function(){
  var all=[];Object.values(allQ).forEach(function(a){all=all.concat(a)});startRev('جميع الأقسام',all);
});
document.getElementById('qax-all-exam').addEventListener('click',function(){
  var all=[];Object.values(allQ).forEach(function(a){all=all.concat(a)});startExam('جميع الأقسام',all);
});
document.getElementById('qax-rev-back').addEventListener('click',function(){qaxGo('cats')});
document.getElementById('qax-rev-prev').addEventListener('click',function(){if(idx>0){idx--;renderRev()}});
document.getElementById('qax-rev-next').addEventListener('click',function(){
  if(idx<qs.length-1){idx++;renderRev()}
  else{
    var sub=document.getElementById('qax-done-sub');sub.innerHTML='';
    sub.appendChild(document.createTextNode('راجعت '));
    var s=document.createElement('strong');s.textContent=qs.length;sub.appendChild(s);
    sub.appendChild(document.createTextNode(' سؤالا من قسم '));
    var s2=document.createElement('strong');s2.textContent=catName;sub.appendChild(s2);
    qaxGo('revdone');
  }
});
document.getElementById('qax-done-again').addEventListener('click',function(){idx=0;qaxGo('rev');renderRev()});
document.getElementById('qax-done-cats').addEventListener('click',function(){qaxGo('cats')});
document.getElementById('qax-exam-back').addEventListener('click',function(){qaxGo('cats')});
document.getElementById('qax-exam-nxt').addEventListener('click',function(){
  if(idx<qs.length-1){idx++;renderExam()}else showResult();
});
document.getElementById('qax-res-retry').addEventListener('click',function(){startExam(catName,qs)});
document.getElementById('qax-res-cats').addEventListener('click',function(){qaxGo('cats')});

/* ── start ── */
load();
})();
</script>
