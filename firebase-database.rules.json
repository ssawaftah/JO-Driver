{
  "rules": {
    ".read": false,
    ".write": false,

    "admin": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid"
      }
    },

    "questions": {
      ".read": true,
      ".write": "auth != null && root.child('admin').child(auth.uid).exists()"
    },

    "centers": {
      ".read": true,
      ".write": "auth != null && root.child('admin').child(auth.uid).exists()"
    },

    "governorates": {
      ".read": true,
      ".write": "auth != null && root.child('admin').child(auth.uid).exists()"
    },

    "areas": {
      ".read": true,
      "$aid": {
        ".write": "(!data.exists()) || (auth != null && root.child('admin').child(auth.uid).exists())",
        ".validate": "newData.hasChildren(['name','governorateId']) && newData.child('name').isString() && newData.child('name').val().length > 0 && newData.child('name').val().length < 80 && newData.child('governorateId').isString()",
        "name": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length < 80" },
        "governorateId": { ".validate": "newData.isString() && root.child('governorates').child(newData.val()).exists()" },
        "$other": { ".validate": false }
      }
    },

    "reviews": {
      ".read": true,
      "$rid": {
        ".write": "(auth != null && !data.exists()) || (auth != null && root.child('admin').child(auth.uid).exists())"
      }
    },

    "CenterRequests": {
      ".read": "auth != null && root.child('admin').child(auth.uid).exists()",
      "$rid": {
        ".write": "(!data.exists()) || (auth != null && root.child('admin').child(auth.uid).exists())"
      }
    },

    "users": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admin').child(auth.uid).exists())",
        ".write": "auth != null && (auth.uid === $uid || root.child('admin').child(auth.uid).exists())"
      }
    }
  }
}
