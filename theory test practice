<!-- ==================== JavaScript ==================== -->
<script>
(function () {

  /* ——— إعداد Firebase ——— */
  var FIREBASE_CONFIG = {
    apiKey: "AIzaSyDsN-OmtB-XFKGsYmX6zh_VvInCyE-rKtk",
    authDomain: "al3arbicv.firebaseapp.com",
    databaseURL: "https://al3arbicv-default-rtdb.asia-southeast1.firebasedatabase.app",
    projectId: "al3arbicv"
  };

  /* ——— ثوابت الامتحان ——— */
  var EXAM_TOTAL = 60;
  var EXAM_MINS  = 60;
  var MAX_WRONG  = 9;
  var CIRC       = 326.73; /* 2 * π * 52 */

  /* ——— حالة الامتحان ——— */
  var allQuestions = [];
  var queue = [], answers = [], currentIdx = 0, selected = null;
  var secsLeft = EXAM_MINS * 60, wrongCount = 0, correctCount = 0, timerId = null;
  var milestoneShown = false;
  var resOk = 0, resWrong = 0, resTotal = 0, resSkipped = 0;

  /* ——— مراجع العناصر ——— */
  var screenLoading  = document.getElementById('dex-loading');
  var screenRules    = document.getElementById('dex-rules');
  var screenExam     = document.getElementById('dex-exam');
  var screenResult   = document.getElementById('dex-result');

  var elTimer        = document.getElementById('dex-timer');
  var elTimerText    = document.getElementById('dex-timer-text');
  var elQnum         = document.getElementById('dex-qnum');
  var elWrongCtr     = document.getElementById('dex-wrong-ctr');
  var elWrongText    = document.getElementById('dex-wrong-text');
  var elProgressFill = document.getElementById('dex-progress-fill');
  var elMediaWrap    = document.getElementById('dex-media-wrap');
  var elMediaImg     = document.getElementById('dex-media-img');
  var elMediaVideo   = document.getElementById('dex-media-video');
  var elQuestion     = document.getElementById('dex-question');
  var elOptions      = document.getElementById('dex-options');
  var elSkipBtn      = document.getElementById('dex-skip-btn');
  var elConfirmBtn   = document.getElementById('dex-confirm-btn');
  var elConfirmIcon  = document.getElementById('dex-confirm-icon');
  var elConfirmText  = document.getElementById('dex-confirm-text');
  var elMilestone    = document.getElementById('dex-milestone');
  var elMsCount      = document.getElementById('dex-ms-count');
  var elMsFinish     = document.getElementById('dex-ms-finish');
  var elMsContinue   = document.getElementById('dex-ms-continue');

  var elResultScreen = document.getElementById('dex-result');
  var elResultIcon   = document.getElementById('dex-result-icon');
  var elResultTitle  = document.getElementById('dex-result-title');
  var elResultSub    = document.getElementById('dex-result-sub');
  var elCircleArc    = document.getElementById('dex-circle-arc');
  var elResultPct    = document.getElementById('dex-result-pct');
  var elStatOk       = document.getElementById('dex-stat-ok');
  var elStatWrong    = document.getElementById('dex-stat-wrong');
  var elStatSkip     = document.getElementById('dex-stat-skip');
  var elStatTotal    = document.getElementById('dex-stat-total');
  var elDetailIconEl = document.getElementById('dex-detail-icon-el');
  var elDOk1         = document.getElementById('dex-d-ok1');
  var elDTotal1      = document.getElementById('dex-d-total1');
  var elDPct1        = document.getElementById('dex-d-pct1');
  var elDOk2         = document.getElementById('dex-d-ok2');
  var elDTotal2      = document.getElementById('dex-d-total2');
  var elNoQs         = document.getElementById('dex-no-qs');
  var elStartBtn     = document.getElementById('dex-start-btn');
  var elRetryBtn     = document.getElementById('dex-retry-btn');

  /* ——— إدارة الشاشات ——— */
  function showScreen(screen) {
    [screenLoading, screenRules, screenExam, screenResult].forEach(function (s) {
      s.classList.remove('dex-active');
    });
    screen.classList.add('dex-active');
  }

  /* ——— تنسيق الوقت ——— */
  function pad(n) { return String(n).padStart(2, '0'); }

  /* ——— تهيئة Firebase ——— */
  function initFirebase() {
    if (!window.firebase) return null;
    if (!firebase.apps || !firebase.apps.length) {
      firebase.initializeApp(FIREBASE_CONFIG);
    } else {
      try { firebase.app(); } catch (e) { firebase.initializeApp(FIREBASE_CONFIG); }
    }
    return firebase.database();
  }

  /* ——— تحميل الأسئلة ——— */
  function loadData() {
    var db = initFirebase();
    if (!db) { setTimeout(loadData, 300); return; }
    db.ref('questions').once('value')
      .then(function (snap) {
        var raw = snap.val() || {};
        allQuestions = Object.values(raw).filter(function (q) {
          return q.question && q.options && q.options.length >= 2;
        });
        showRules();
      })
      .catch(function () { showRules(); });
  }

  /* ——— شاشة القواعد ——— */
  function showRules() {
    if (allQuestions.length === 0) {
      elNoQs.classList.remove('dex-hidden');
      elStartBtn.disabled = true;
    } else {
      elNoQs.classList.add('dex-hidden');
      elStartBtn.disabled = false;
    }
    showScreen(screenRules);
  }

  /* ——— بدء الامتحان ——— */
  function startExam() {
    var shuffled = allQuestions.slice().sort(function () { return Math.random() - 0.5; });
    queue          = shuffled.slice(0, Math.min(EXAM_TOTAL, shuffled.length));
    answers        = new Array(queue.length).fill(null);
    currentIdx     = 0;
    selected       = null;
    secsLeft       = EXAM_MINS * 60;
    wrongCount     = 0;
    correctCount   = 0;
    milestoneShown = false;
    elMilestone.classList.add('dex-hidden');

    showScreen(screenExam);
    renderQuestion();

    timerId = setInterval(function () {
      secsLeft--;
      if (secsLeft <= 0) {
        clearInterval(timerId);
        timerId = null;
        finishExam();
      } else {
        updateStatusBar();
      }
    }, 1000);
  }

  /* ——— تحديث شريط الحالة ——— */
  function updateStatusBar() {
    var mins = Math.floor(secsLeft / 60);
    var secs = secsLeft % 60;
    var warn = secsLeft < 300;
    var totalAnswered = answers.filter(function (a) { return a !== null; }).length;
    var danger = wrongCount >= 7;

    elTimerText.textContent = pad(mins) + ':' + pad(secs);
    elTimer.classList.toggle('dex-timer-warn', warn);
    elWrongText.textContent = wrongCount + '/' + (MAX_WRONG + 1);
    elWrongCtr.classList.toggle('dex-wrong-danger', danger);
    elProgressFill.style.width = ((totalAnswered / EXAM_TOTAL) * 100) + '%';
    elProgressFill.classList.toggle('dex-progress-fill-danger', danger);
  }

  /* ——— عرض السؤال الحالي ——— */
  function renderQuestion() {
    var q      = queue[currentIdx];
    var isLast = currentIdx >= queue.length - 1;
    var hasSelection = selected !== null;

    /* رقم السؤال */
    elQnum.textContent = (currentIdx + 1) + ' / ' + queue.length;
    updateStatusBar();

    /* الوسائط */
    elMediaWrap.classList.add('dex-hidden');
    elMediaImg.classList.add('dex-hidden');
    elMediaVideo.classList.add('dex-hidden');
    elMediaImg.src   = '';
    elMediaVideo.src = '';

    if (q.mediaUrl && q.mediaType !== 'text') {
      elMediaWrap.classList.remove('dex-hidden');
      if (q.mediaType === 'video') {
        elMediaVideo.src = q.mediaUrl;
        elMediaVideo.classList.remove('dex-hidden');
      } else {
        elMediaImg.src = q.mediaUrl;
        elMediaImg.classList.remove('dex-hidden');
      }
    }

    /* نص السؤال */
    elQuestion.textContent = q.question;

    /* الخيارات */
    elOptions.innerHTML = '';
    var letters = ['A', 'B', 'C', 'D', 'E'];
    q.options.forEach(function (optText, i) {
      var btn = document.createElement('button');
      btn.className = 'dex-option' + (selected === i ? ' dex-option-selected' : '');

      var badge = document.createElement('div');
      badge.className = 'dex-option-badge';

      var letterSpan = document.createElement('span');
      letterSpan.className = 'dex-badge-letter';
      letterSpan.textContent = letters[i] || String(i + 1);

      var checkIcon = document.createElement('i');
      checkIcon.className = 'ph ph-check dex-badge-check';

      badge.appendChild(letterSpan);
      badge.appendChild(checkIcon);

      var textSpan = document.createElement('span');
      textSpan.className = 'dex-option-text';
      textSpan.textContent = optText;

      btn.appendChild(badge);
      btn.appendChild(textSpan);

      btn.addEventListener('click', function () {
        selected = i;
        renderQuestion();
      });

      elOptions.appendChild(btn);
    });

    /* زر التأكيد */
    elConfirmBtn.disabled = !hasSelection;
    elConfirmBtn.classList.toggle('dex-confirm-last', hasSelection && isLast);

    if (isLast && hasSelection) {
      elConfirmIcon.className = 'ph ph-flag-checkered dex-confirm-icon';
      elConfirmText.textContent = 'إنهاء الاختبار';
    } else {
      elConfirmIcon.className = 'ph ph-arrow-left dex-confirm-icon';
      elConfirmText.textContent = 'تأكيد والتالي';
    }
  }

  /* ——— تخطي السؤال ——— */
  function skipQuestion() {
    var skippedQ = queue.splice(currentIdx, 1)[0];
    queue.push(skippedQ);
    var skippedA = answers.splice(currentIdx, 1)[0];
    answers.push(skippedA);
    selected = null;
    if (currentIdx >= queue.length) {
      clearInterval(timerId);
      timerId = null;
      finishExam();
    } else {
      renderQuestion();
    }
  }

  /* ——— تأكيد الإجابة ——— */
  function confirmAnswer() {
    if (selected === null) return;
    var q       = queue[currentIdx];
    var isWrong = selected !== q.correctAnswer;
    var isLast  = currentIdx >= queue.length - 1;
    answers[currentIdx] = selected;

    if (!isWrong) {
      correctCount++;
      /* إشعار النجاح عند الوصول لـ 51 إجابة صحيحة (مرة واحدة فقط) */
      if (correctCount >= 51 && !milestoneShown) {
        milestoneShown = true;
        elMsCount.textContent = correctCount;
        elMilestone.classList.remove('dex-hidden');
        selected = null;
        currentIdx++;
        return;
      }
    } else {
      wrongCount++;
    }

    selected = null;
    if (wrongCount > MAX_WRONG || isLast) {
      clearInterval(timerId);
      timerId = null;
      finishExam();
    } else {
      currentIdx++;
      renderQuestion();
    }
  }

  /* ——— إشعار النجاح: إنهاء الاختبار ——— */
  function milestoneFinish() {
    elMilestone.classList.add('dex-hidden');
    clearInterval(timerId);
    timerId = null;
    finishExam();
  }

  /* ——— إشعار النجاح: متابعة الأسئلة ——— */
  function milestoneContinue() {
    elMilestone.classList.add('dex-hidden');
    renderQuestion();
  }

  /* ——— إنهاء الامتحان ——— */
  function finishExam() {
    if (timerId) { clearInterval(timerId); timerId = null; }
    var ok = 0, wr = 0, sk = 0;
    queue.forEach(function (q, i) {
      var a = answers[i];
      if (a === null)                 sk++;
      else if (a === q.correctAnswer) ok++;
      else                            wr++;
    });
    resOk      = ok;
    resWrong   = wr;
    resTotal   = queue.length;
    resSkipped = sk;
    showResult();
  }

  /* ——— شاشة النتيجة ——— */
  function showResult() {
    var passed = resWrong <= 9 && resOk >= 51;
    var pct    = resTotal > 0 ? Math.round((resOk / resTotal) * 100) : 0;
    var dash   = CIRC - (pct / 100) * CIRC;

    /* حالة النجاح/الرسوب على حاوية النتيجة */
    elResultScreen.classList.remove('dex-result-passed', 'dex-result-failed', 'dex-fail-wrongs', 'dex-fail-low');
    if (passed) {
      elResultScreen.classList.add('dex-result-passed');
    } else {
      elResultScreen.classList.add('dex-result-failed');
      elResultScreen.classList.add(resWrong > 9 ? 'dex-fail-wrongs' : 'dex-fail-low');
    }

    /* الأيقونة */
    elResultIcon.className = 'ph ' + (passed ? 'ph-seal-check' : 'ph-seal-warning');
    elDetailIconEl.className = 'ph ' + (passed ? 'ph-check-circle' : 'ph-x-circle') + ' dex-detail-icon-el';

    /* النصوص */
    elResultTitle.textContent = passed ? 'مبروك! اجتزت الاختبار 🎉' : 'لم تجتز الاختبار';
    elResultSub.textContent   = passed
      ? 'أداء ممتاز! أنت مؤهل لاجتياز الفحص النظري الرسمي'
      : (resWrong > 9
        ? 'تم إيقاف الاختبار لتجاوز الحد الأقصى للإجابات الخاطئة'
        : 'راجع المزيد من الأسئلة وحاول مجدداً');

    /* دائرة النسبة */
    elResultPct.textContent = pct + '%';
    elCircleArc.setAttribute('stroke-dashoffset', dash);

    /* الإحصائيات */
    elStatOk.textContent    = resOk;
    elStatWrong.textContent = resWrong;
    elStatSkip.textContent  = resSkipped;
    elStatTotal.textContent = resTotal;

    /* نصوص التفاصيل الديناميكية */
    elDOk1.textContent    = resOk;
    elDTotal1.textContent = resTotal;
    elDPct1.textContent   = pct + '%';
    elDOk2.textContent    = resOk;
    elDTotal2.textContent = resTotal;

    showScreen(screenResult);
  }

  /* ——— ربط الأحداث ——— */
  elStartBtn.addEventListener('click', startExam);
  elSkipBtn.addEventListener('click', skipQuestion);
  elConfirmBtn.addEventListener('click', confirmAnswer);
  elMsFinish.addEventListener('click', milestoneFinish);
  elMsContinue.addEventListener('click', milestoneContinue);
  elRetryBtn.addEventListener('click', function () {
    showRules();
  });

  /* ——— تشغيل التطبيق ——— */
  loadData();

}());
</script>
