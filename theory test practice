        </div>

        <!-- قواعد الاختبار -->
        <h3 class="dex-rules-heading">قواعد الاختبار:</h3>
        <ul class="dex-rules-list">
          <li class="dex-rule-item" data-color="blue">
            <div class="dex-rule-icon"><i class="ph ph-list-numbers"></i></div>
